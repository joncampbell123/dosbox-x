
// modregrm: mod/reg/rm byte field and possibly displacement field following it
// mem: memory
// effective mem: memory location, but instead of reading the memory location, the memory location address is the value
// greg: general register
// mem|greg: memory or general register
// sreg: segment register
// stack: data comes from stack
// byte: byte size
// word: word (16-bit) size
// dword: dword (32-bit) size
// qword: qword (64-bit) size
// default word: default word size according to CPU mode and override (word if 16-bit, dword if 32-bit)
// ignore: within a set or range, to ignore the value
// immediate: immediate value

// popcs: set if 8086 decoding (pop CS), unset otherwise (0x0F prefix)

/////////////////////////////////////////////////////////////////////////////////////////////////////
// 8086
/////////////////////////////////////////////////////////////////////////////////////////////////////
// [http://hackipedia.org/browse.cgi/Computer/Platform/PC%2c%20IBM%20compatible/CPU/8086/Intel/8086%2016%2dbit%20HMOS%20Microprocessor%2c%208086%2c%208086%2d2%2c%208086%2d1%20%281990%2d09%29%2epdf]
// [http://ref.x86asm.net/coder32.html]
// [http://www.mlsite.net/8086/]

opcode b1=[0x00...0x03] { // 000000dw mod/reg/rm
	name = "add";
	dest = (b1&2)?greg:mem|greg;
	src = (b1&2)?mem|greg:greg;
	size = (b1&1)?default word:byte;
}
opcode b1=[0x04...0x05] immediate { // 0000011w immediate
	name = "add";
	dest = greg(a);
	src = immediate;
	size = (b1&1)?default word:byte;
}
opcode b1=[0x08...0x0B] { // 000010dw mod/reg/rm
	name = "or";
	dest = (b1&2)?greg:mem|greg;
	src = (b1&2)?mem|greg:greg;
	size = (b1&1)?default word:byte;
}
opcode b1=[0x0C...0x0D] immediate { // 0000111w immediate
	name = "or";
	dest = greg(a);
	src = immediate;
	size = (b1&1)?default word:byte;
}
opcode b1=[0x10...0x13] { // 000100dw mod/reg/rm
	name = "adc";
	dest = (b1&2)?greg:mem|greg;
	src = (b1&2)?mem|greg:greg;
	size = (b1&1)?default word:byte;
}
opcode b1=[0x14...0x15] immediate { // 0001011w immediate
	name = "adc";
	dest = greg(a);
	src = immediate;
	size = (b1&1)?default word:byte;
}
opcode b1=[0x18...0x1B] { // 000110dw mod/reg/rm
	name = "sbb";
	dest = (b1&2)?greg:mem|greg;
	src = (b1&2)?mem|greg:greg;
	size = (b1&1)?default word:byte;
}
opcode b1=[0x1C...0x1D] immediate { // 0001111w immediate
	name = "sbb";
	dest = greg(a);
	src = immediate;
	size = (b1&1)?default word:byte;
}
opcode b1=[0x06,0x0E,0x16,0x1E] { // 0000rr110
	name = "push";
	dest = push stack;
	src = sreg(b1>>3);
	size = default word;
}
opcode b1=[0x07,popcs?0x0F:ignore,0x17,0x1F] { // 0000rr111
	name = "pop";
	dest = sreg(b1>>3);
	src = stack pop;
	size = default word;
}
opcode b1=[0x50...0x57] { // 01010reg
	name = "push";
	dest = push stack;
	src = greg(b1&7);
	size = default word;
}
opcode b1=[0x58...0x5F] { // 01011reg
	name = "pop";
	dest = greg(b1&7);
	src = stack pop;
	size = default word;
}
opcode b1=[0x88...0x8B] modregrm { // 100010dw
	name = "mov";
	dest = (b1&2)?greg:mem|greg;
	src = (b1&2)?mem|greg:greg;
	size = (b1&1)?default word:byte;
}
opcode b1=[0x8C,0x8E] modregrm { // 100011d0
	name = "mov";
	dest = (b1&2)?sreg:mem|greg;
	src = (b1&2)?mem|greg:sreg;
	size = default word;
}
opcode 0x8D modregrm(reg < 4 && rm == mem) { // 10001101 mm/0rr/ggg and r/m must refer to memory (mod != 3)
	name = "lea";
	dest = greg;
	src = effective mem;
	size = default word;
}
opcode 0x8F modregrm(reg == 0) { // 10001111 mm/000/ggg
	name = "pop";
	dest = greg;
	src = stack pop;
	size = default word;
}
opcode 0xFF modregrm(reg == 6) { // 11111111 mm/110/ggg
	name = "push";
	dest = push stack;
	src = greg;
	size = default word;
}

